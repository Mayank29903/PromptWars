# ═══════════════════════════════════════════════════════════════════════
#  ANTIGRAVITY — Root Environment Variables
#  Copy this file to .env and fill in values.
#  Usage:  cp .env.example .env
#  All services read from docker-compose.dev.yml env or this file.
# ═══════════════════════════════════════════════════════════════════════

# ── Infrastructure ────────────────────────────────────────────────────

# PostgreSQL connection string (used by api-gateway Prisma ORM)
DATABASE_URL=postgresql://admin:password@localhost:5432/antigravity

# Redis connection URL (used by all services for shared state)
REDIS_URL=redis://localhost:6379

# Kafka broker addresses (comma-separated for multi-broker clusters)
KAFKA_BROKERS=localhost:9092

# ── Security ──────────────────────────────────────────────────────────

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=change_me_in_production_use_openssl_rand_hex_32

# Environment: development | production
NODE_ENV=development

# ── API Gateway (port 3000) ───────────────────────────────────────────

API_GATEWAY_PORT=3000
API_GATEWAY_HOST=0.0.0.0

# Rate limiting: max requests per window
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# ── Real-Time Service (port 3001) ─────────────────────────────────────

REALTIME_SERVICE_PORT=3001
REALTIME_SERVICE_URL=http://localhost:3001

# Dashboard origin for CORS
CORS_ORIGINS=http://localhost:5173

# ── Edge Processor (port 3002) ────────────────────────────────────────

EDGE_PROCESSOR_PORT=3002

# ── Notification Service (port 3003) ──────────────────────────────────

NOTIFICATION_SERVICE_PORT=3003

# ── ML Service (port 8000) ────────────────────────────────────────────

ML_SERVICE_PORT=8000
ML_SERVICE_URL=http://localhost:8000

# ── SafetyNet Service (port 8001) ─────────────────────────────────────

SAFETY_SERVICE_PORT=8001
SAFETY_SERVICE_URL=http://localhost:8001

# API Gateway URL (for incident creation during emergencies)
API_GATEWAY_URL=http://localhost:3000

# ── FanPulse Service (port 8002) ──────────────────────────────────────

FAN_PULSE_SERVICE_PORT=8002

# ── PredictEngine Service (port 8003) ─────────────────────────────────

PREDICT_ENGINE_PORT=8003
