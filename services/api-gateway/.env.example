NODE_ENV=development
PORT=3000
HOST=0.0.0.0
DATABASE_URL=postgresql://admin:password@localhost:5432/antigravity
REDIS_URL=redis://localhost:6379
KAFKA_BROKERS=localhost:9092
JWT_SECRET=your-256-bit-secret-for-dev-only
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
BCRYPT_ROUNDS=12
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000
ML_SERVICE_URL=http://localhost:8000
REALTIME_SERVICE_URL=http://localhost:3001
SAFETY_SERVICE_URL=http://localhost:8001
PREDICT_SERVICE_URL=http://localhost:8003

# Optional: enables Gemini AI for natural language venue queries.
# Get key from https://aistudio.google.com/app/apikey (free tier available).
# Leave blank to use rule-based fallback — demo will still work without it.
GEMINI_API_KEY=your-gemini-api-key-here
